# Convex — from https://dashboard.convex.dev
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Clerk — from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk issuer URL — from Clerk dashboard → API Keys → Advanced
# Format: https://your-app.clerk.accounts.dev
CLERK_ISSUER_URL=https://your-app.clerk.accounts.dev

# Clerk redirect URLs (optional — defaults work for most setups)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/clinics/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/clinics/dashboard
